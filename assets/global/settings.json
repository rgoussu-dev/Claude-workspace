{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "allow": [
      "Bash(git status)",
      "Bash(git status:*)",
      "Bash(git diff)",
      "Bash(git diff:*)",
      "Bash(git log)",
      "Bash(git log:*)",
      "Bash(git show)",
      "Bash(git show:*)",
      "Bash(git branch)",
      "Bash(git branch:*)",
      "Bash(git stash list)",
      "Bash(git stash list:*)",
      "Bash(git remote -v)",
      "Bash(git remote show:*)",
      "Bash(git ls-files:*)",
      "Bash(git blame:*)",
      "Bash(git rev-parse:*)",

      "Bash(rg:*)",
      "Bash(fd:*)",
      "Bash(tree:*)",
      "Bash(wc:*)",
      "Bash(file:*)",
      "Bash(stat:*)",

      "Bash(pnpm run lint)",
      "Bash(pnpm run lint:*)",
      "Bash(pnpm run format)",
      "Bash(pnpm run format:*)",
      "Bash(pnpm run typecheck)",
      "Bash(pnpm run test)",
      "Bash(pnpm run test:*)",
      "Bash(pnpm run build)",
      "Bash(pnpm run build:*)",
      "Bash(pnpm exec vitest:*)",
      "Bash(pnpm exec tsc:*)",
      "Bash(pnpm exec prettier:*)",
      "Bash(pnpm exec eslint:*)",

      "Bash(npm test)",
      "Bash(npm run lint)",
      "Bash(npm run format)",
      "Bash(npm run typecheck)",
      "Bash(npm run build)",

      "Bash(./gradlew check)",
      "Bash(./gradlew build)",
      "Bash(./gradlew test)",
      "Bash(./gradlew spotlessCheck)",
      "Bash(./gradlew spotlessApply)",
      "Bash(./gradlew compileJava)",
      "Bash(./gradlew compileKotlin)",
      "Bash(./gradlew pitest)",
      "Bash(./gradlew archTest)",
      "Bash(./gradlew :**:test)",

      "Bash(cargo check)",
      "Bash(cargo check:*)",
      "Bash(cargo build)",
      "Bash(cargo build:*)",
      "Bash(cargo test)",
      "Bash(cargo test:*)",
      "Bash(cargo clippy)",
      "Bash(cargo clippy:*)",
      "Bash(cargo fmt)",
      "Bash(cargo fmt:*)",
      "Bash(cargo mutants)",
      "Bash(cargo mutants:*)",

      "Bash(go build)",
      "Bash(go build:*)",
      "Bash(go test)",
      "Bash(go test:*)",
      "Bash(go vet)",
      "Bash(go vet:*)",
      "Bash(gofmt:*)",
      "Bash(staticcheck:*)",

      "Bash(tofu init)",
      "Bash(tofu validate)",
      "Bash(tofu fmt)",
      "Bash(tofu plan)",
      "Bash(tofu plan:*)",

      "Read",
      "Grep",
      "Glob"
    ],
    "ask": [
      "Bash(git push:*)",
      "Bash(git reset:*)",
      "Bash(git rebase:*)",
      "Bash(git cherry-pick:*)",
      "Bash(tofu apply:*)",
      "Bash(tofu destroy:*)"
    ],
    "deny": [
      "Bash(git push --force:*)",
      "Bash(git push -f:*)",
      "Bash(git reset --hard:*)",
      "Bash(rm -rf /:*)",
      "Bash(sudo:*)"
    ]
  },
  "env": {
    "KEEL_ENFORCE_HEXAGONAL": "true",
    "KEEL_ENFORCE_TRUNK_BASED": "true",
    "KEEL_ENFORCE_PUBLIC_API_DOCS": "true"
  }
}
