package <%= basePackage %>.cli;

import java.util.List;

import jakarta.enterprise.context.ApplicationScoped;
import jakarta.enterprise.inject.Produces;
import jakarta.inject.Singleton;

import <%= basePackage %>.contract.Handler;
import <%= basePackage %>.contract.Mediator;
import <%= basePackage %>.core.DefaultMediator;
import <%= basePackage %>.core.greet.GreetHandler;

/**
 * Hand-wires the Mediator with every domain Handler. Replace with
 * CDI lookup of all {@link Handler} beans once the project grows
 * past one or two handlers.
 */
@ApplicationScoped
public class MediatorProducer {

    @Produces
    @Singleton
    public Mediator mediator() {
        List<Handler<?, ?>> handlers = List.of(new GreetHandler());
        return new DefaultMediator(handlers);
    }
}
